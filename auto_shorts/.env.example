# ─────────────────────────────────────────
#  FREE AGENTIC VIDEO PIPELINE — .env setup
# ─────────────────────────────────────────

# ── LLM (pick one, both are free) ──────
GEMINI_API_KEY= "AIzaSyDvqZybsIduV4gyF4qOGxC_2XSGmm-MTe0"    # aistudio.google.com → Get API key
GROQ_API_KEY=your_groq_key_here              # console.groq.com → Free tier

LLM_PROVIDER=gemini                          # "gemini" or "groq"

# ── Stock Media ────────────────────────
PEXELS_API_KEY= "3zcKSGDuiKTqiVKLNwBT8PNrtDB92mEm7WAGKgmStMOAA66CbCyDcTDo"        # pexels.com/api → Free, 200 req/hr
PIXABAY_API_KEY=your_pixabay_key_here        # pixabay.com/api → Free

# ── TTS (edge-tts needs NO key) ────────
TTS_ENGINE=edge                              # "edge" (no key) or "kokoro" (local)
TTS_VOICE=en-US-AriaNeural                  # edge-tts voice name

# ── YouTube ────────────────────────────
YOUTUBE_CLIENT_ID=your_yt_client_id         # console.cloud.google.com
YOUTUBE_CLIENT_SECRET=your_yt_client_secret
YOUTUBE_TOKEN_FILE=config/yt_token.json     # auto-generated after first auth

# ── Instagram Graph API ─────────────────
INSTAGRAM_ACCESS_TOKEN=your_ig_token        # developers.facebook.com
INSTAGRAM_BUSINESS_ID=your_ig_business_id

# ── Scheduler ──────────────────────────
SCHEDULE_INTERVAL_HOURS=24                  # how often to post (24 = daily)
MAX_VIDEOS_PER_DAY=1                        # stay safe with YT quota

# ── General ────────────────────────────
VIDEO_DURATION_SECONDS=50                   # target video length
OUTPUT_DIR=output/videos
FFMPEG_BIN=C:\ffmpeg\bin                   # optional: folder containing ffmpeg.exe and ffprobe.exe
LOG_LEVEL=INFO
